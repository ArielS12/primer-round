# Copiá este archivo como `.env.local` para desarrollo o `.env.production` para builds.
# En Render, configurá estas variables desde el Dashboard del servicio (no las commitees).

# URL pública absoluta del sitio. Se usa en `metadataBase` (Open Graph, SEO).
# - En desarrollo: http://localhost:3000
# - En Render:    https://<nombre-del-servicio>.onrender.com
#                 o el dominio personalizado si configurás uno.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
